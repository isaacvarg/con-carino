enum CareCoverageFrequency {
  WEEKLY
  BIWEEKLY
}

enum CareCoverageNeed {
  FULL
  PARTIAL
}

enum CareCoverageWindowKind {
  ALL_DAY
  SHIFTS
}

enum CareOccurrenceStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum CareSwapStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CareSwapItemRole {
  /// Currently the target person's window; moves to the requester person
  TAKE
  /// Currently the requester person's window; moves to the target person
  GIVE
}

enum CareInvoiceStatus {
  OPEN
  PAID
  VOID
}

enum CarePayInterval {
  PER_SHIFT
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum CareRateType {
  HOURLY
  DAILY
}

enum CareBillingStatus {
  NOT_BILLABLE
  ACCRUED
  INVOICED
}

enum CareAssignmentScope {
  ALL_SHIFTS
  SPECIFIC_SHIFTS
}

/// Singleton settings for the one loved one on this app instance.
model CareSettings {
  id                   String                 @id @default("default")
  lovedOneName         String                 @default("")
  coverageNeed         CareCoverageNeed       @default(FULL)
  coverageWindowKind   CareCoverageWindowKind @default(ALL_DAY)
  /// Days of week 0=Sun … 6=Sat; used when coverageNeed is PARTIAL
  partialDaysOfWeek    Int[]                  @default([])
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  shifts CareRequiredShift[]

  @@map("care_settings")
}

model CareRequiredShift {
  id         String   @id @default(uuid())
  settingsId String   @default("default")
  label      String?
  /// Local wall time "HH:mm"
  startTime  String
  /// Local wall time "HH:mm"
  endTime    String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  settings CareSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  requiredSeries CareCoverageSeries[]

  @@index([settingsId, sortOrder])
  @@map("care_required_shifts")
}

model CarePersonType {
  id         String   @id @default(uuid())
  name       String   @unique
  isPaid     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  people CarePerson[]

  @@map("care_person_types")
}

model CarePerson {
  id            String          @id @default(uuid())
  name          String
  userId        String?         @unique
  typeId        String
  hourlyRate    Decimal?        @db.Decimal(19, 4)
  /// Whether hourlyRate is charged per hour or as a flat daily amount
  rateType      CareRateType    @default(HOURLY)
  /// When true and rateType is DAILY, bill the full daily rate per calendar day
  /// covered, regardless of hours actually worked in the window
  flatDailyRate Boolean         @default(false)
  /// When to create period invoices; only applies when type.isPaid
  payInterval   CarePayInterval @default(PER_SHIFT)
  /// 0=Sun … 6=Sat; used for WEEKLY / BIWEEKLY
  payWeekday    Int?
  /// Known payday date; anchors BIWEEKLY alignment
  payAnchorDate DateTime?       @db.Date
  /// 1–28; used for MONTHLY
  payMonthDay   Int?
  isActive      Boolean         @default(true)
  bgColor       String?
  textColor     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  type          CarePersonType            @relation(fields: [typeId], references: [id], onDelete: Restrict)
  series        CareCoverageSeries[]
  occurrences   CareCoverageOccurrence[]
  assignmentRules CareCoverageAssignmentRule[]
  swapsRequested CareSwapRequest[]        @relation("SwapRequesterPerson")
  swapsTargeted  CareSwapRequest[]        @relation("SwapTargetPerson")
  invoices      CareInvoice[]

  @@index([typeId])
  @@map("care_people")
}

model CareCoverageSeries {
  id               String                 @id @default(uuid())
  assigneeId       String?
  startsOn         DateTime               @db.Date
  endsOn           DateTime?              @db.Date
  /// Local wall time "HH:mm"
  startTime        String
  /// Local wall time "HH:mm"
  endTime          String
  frequency        CareCoverageFrequency
  /// Days of week 0=Sun … 6=Sat
  daysOfWeek       Int[]
  notes            String?
  /// System series produced from loved-one required coverage settings
  isRequired       Boolean                @default(false)
  requiredKey      String?
  /// Stable required-shift identity for SHIFTS windows; null for ALL_DAY/manual
  requiredShiftId  String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  assignee    CarePerson?              @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  requiredShift CareRequiredShift?     @relation(fields: [requiredShiftId], references: [id], onDelete: SetNull)
  occurrences CareCoverageOccurrence[]

  @@index([assigneeId])
  @@index([isRequired])
  @@index([requiredShiftId])
  @@unique([requiredKey])
  @@map("care_coverage_series")
}

model CareCoverageOccurrence {
  id            String                @id @default(uuid())
  seriesId      String?
  assigneeId    String?
  /// Set when an assignment rule auto-filled this slot; enables clean revert
  assignedByRuleId String?
  startsAt      DateTime
  endsAt        DateTime
  status        CareOccurrenceStatus  @default(SCHEDULED)
  billingStatus CareBillingStatus     @default(NOT_BILLABLE)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  series           CareCoverageSeries? @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  assignee         CarePerson?         @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  assignedByRule   CareCoverageAssignmentRule? @relation(fields: [assignedByRuleId], references: [id], onDelete: SetNull)
  invoiceLine      CareInvoiceLine?
  swapItems        CareSwapItem[]

  @@unique([seriesId, startsAt])
  @@index([startsAt, endsAt])
  @@index([assigneeId])
  @@index([assignedByRuleId])
  @@index([status])
  @@index([billingStatus])
  @@map("care_coverage_occurrences")
}

/// Persistent rule that assigns a person to required coverage on a recurring
/// (weekly) basis. Fills open required occurrences matching its days and shift
/// scope, at creation and as future occurrences materialize.
model CareCoverageAssignmentRule {
  id         String              @id @default(uuid())
  assigneeId String
  startsOn   DateTime            @db.Date
  /// null = indefinite
  endsOn     DateTime?           @db.Date
  /// Days of week 0=Sun … 6=Sat
  daysOfWeek Int[]
  /// Cadence in weeks: 1 = weekly, 2 = every other week, etc. Anchored at startsOn.
  intervalWeeks Int              @default(1)
  scope      CareAssignmentScope @default(ALL_SHIFTS)
  /// Targeted CareRequiredShift ids when scope is SPECIFIC_SHIFTS
  shiftIds   String[]            @default([])
  notes      String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  assignee    CarePerson               @relation(fields: [assigneeId], references: [id], onDelete: Cascade)
  occurrences CareCoverageOccurrence[]

  @@index([assigneeId])
  @@map("care_coverage_assignment_rules")
}

/// User-managed category for calendar events, controlling how the event
/// appears on the calendar (background and text color).
model CareEventType {
  id        String   @id @default(uuid())
  name      String   @unique
  bgColor   String
  textColor String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events CareCalendarEvent[]

  @@map("care_event_types")
}

model CareCalendarEvent {
  id        String   @id @default(uuid())
  typeId    String
  title     String
  startsAt  DateTime
  endsAt    DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type CareEventType @relation(fields: [typeId], references: [id], onDelete: Restrict)

  @@index([typeId])
  @@index([startsAt, endsAt])
  @@map("care_calendar_events")
}

/// A negotiation between two people: the requester takes one or more windows
/// currently assigned to the target person, and optionally gives some of their
/// own windows back. Open (unassigned) windows are never part of a swap — those
/// are handled by the no-approval claim flow.
model CareSwapRequest {
  id                String         @id @default(uuid())
  /// Person receiving the TAKE windows; usually the requester's linked person
  requesterPersonId String
  /// Person losing the TAKE windows
  targetPersonId    String
  requestedByUserId String
  status            CareSwapStatus @default(PENDING)
  reviewedByUserId  String?
  reviewedAt        DateTime?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  requesterPerson CarePerson @relation("SwapRequesterPerson", fields: [requesterPersonId], references: [id], onDelete: Restrict)
  targetPerson    CarePerson @relation("SwapTargetPerson", fields: [targetPersonId], references: [id], onDelete: Restrict)
  requestedByUser User       @relation("SwapRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedByUser  User?      @relation("SwapReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  items           CareSwapItem[]

  @@index([status])
  @@index([targetPersonId, status])
  @@index([requestedByUserId])
  @@map("care_swap_requests")
}

model CareSwapItem {
  id           String           @id @default(uuid())
  swapId       String
  occurrenceId String
  role         CareSwapItemRole

  swap       CareSwapRequest        @relation(fields: [swapId], references: [id], onDelete: Cascade)
  occurrence CareCoverageOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  @@unique([swapId, occurrenceId])
  @@index([occurrenceId])
  @@map("care_swap_items")
}

model CareInvoice {
  id                   String            @id @default(uuid())
  carePersonId         String
  amount               Decimal           @db.Decimal(19, 4)
  status               CareInvoiceStatus @default(OPEN)
  periodStart          DateTime?
  periodEnd            DateTime?
  financialAccountId   String?
  settledTransactionId String?           @unique
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  carePerson         CarePerson        @relation(fields: [carePersonId], references: [id], onDelete: Restrict)
  financialAccount   FinancialAccount? @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  settledTransaction Transaction?      @relation(fields: [settledTransactionId], references: [id], onDelete: SetNull)
  lines              CareInvoiceLine[]

  @@index([status])
  @@index([carePersonId])
  @@map("care_invoices")
}

model CareInvoiceLine {
  id                 String       @id @default(uuid())
  invoiceId          String
  occurrenceId       String       @unique
  amount             Decimal      @db.Decimal(19, 4)
  /// The rate charged (per hour or per day, per rateType)
  hourlyRateSnapshot Decimal      @db.Decimal(19, 4)
  /// Billable quantity: hours when HOURLY, days when DAILY
  hoursSnapshot      Decimal      @db.Decimal(19, 4)
  rateType           CareRateType @default(HOURLY)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  invoice    CareInvoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  occurrence CareCoverageOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@map("care_invoice_lines")
}
