model Attachment {
  id          String   @id @default(uuid())
  userId      String
  storageKey  String   @unique
  fileName    String
  contentType String
  byteSize    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("attachments")
}
