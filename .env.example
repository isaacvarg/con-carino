# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/con_carino?schema=public"

# Auth.js
# Generate one with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Discord OAuth (https://discord.com/developers/applications)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Object storage (RustFS — S3-compatible)
# Local: docker compose up -d
#   API http://127.0.0.1:9000  |  console http://127.0.0.1:9001
# Compose reads S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY for RustFS admin keys — keep them matched.
S3_ENDPOINT="http://127.0.0.1:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="rustfsadmin"
S3_SECRET_ACCESS_KEY="rustfsadmin"
S3_BUCKET="con-carino"
S3_FORCE_PATH_STYLE="true"

# CORS origins for RustFS direct (presigned) browser uploads. Any origin that
# loads the app and PUTs to RustFS must be listed here; without it the upload
# preflight is rejected. Read by RustFS itself (compose passes it through).
# RUSTFS_CORS_ALLOWED_ORIGINS="http://localhost:3000"
