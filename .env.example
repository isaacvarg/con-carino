# PostgreSQL connection string. Used in dev and by prisma.config.ts.
# docker-compose.prod.yml ignores this and composes its own URL from the
# POSTGRES_* vars below.
DATABASE_URL="postgresql://user:password@localhost:5432/con_carino?schema=public"

# Postgres — docker-compose.prod.yml only; the dev stack has no database
# service and uses DATABASE_URL above. The same values configure the postgres
# container and the URL the app connects with, so they can't drift.
# Keep POSTGRES_PASSWORD alphanumeric: it is interpolated into DATABASE_URL
# without escaping, so @ / : or # would corrupt the connection string.
POSTGRES_USER="con_carino"
POSTGRES_PASSWORD=""
POSTGRES_DB="con_carino"

# Auth.js
# Generate one with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Discord OAuth (https://discord.com/developers/applications)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Resend (https://resend.com/api-keys) — magic-link sign-in and swap-request
# emails to linked assignees. AUTH_EMAIL_FROM is required — the app throws at
# boot without it. Accepts a bare address or "Name <addr>". The domain must be
# verified in Resend, or sends fail with a 422. For local testing without DNS
# setup you can use onboarding@resend.dev, which only delivers to your own
# Resend account email. Swap emails no-op if AUTH_RESEND_KEY is empty.
AUTH_RESEND_KEY=""
AUTH_EMAIL_FROM=""

# Object storage (RustFS — S3-compatible)
# Local: docker compose up -d
#   API http://127.0.0.1:9000  |  console http://127.0.0.1:9001
# Compose reads S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY for RustFS admin keys — keep them matched.
S3_ENDPOINT="http://127.0.0.1:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="rustfsadmin"
S3_SECRET_ACCESS_KEY="rustfsadmin"
S3_BUCKET="con-carino"
S3_FORCE_PATH_STYLE="true"

# Files are uploaded and served through same-origin app routes (/api/uploads,
# /api/files) rather than browser-facing presigned URLs, so RustFS needs no
# CORS config and can stay on an internal-only network in production
# (docker-compose.prod.yml). File links are HMAC-signed with AUTH_SECRET.
